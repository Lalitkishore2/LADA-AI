###############################
# LADA - Configuration Template
###############################
# Copy to .env and fill in your values:
#   copy .env.example .env
#
# At minimum, configure ONE AI backend (Gemini recommended).
###############################


###############################
# AI BACKENDS
###############################

# Local Ollama (offline, private, fastest)
# Install: https://ollama.com/download
# Then: ollama pull mistral:7b-instruct-q4_0
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_FAST_MODEL=mistral:7b-instruct-q4_0
LOCAL_SMART_MODEL=neural-chat:7b-v3-q5_K_M

# Google Gemini API (recommended - free tier)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Cloud (fast cloud fallback - free tier)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Cloud
# Get key: https://ollama.com/settings/keys
OLLAMA_CLOUD_URL=https://api.ollama.cloud/v1
OLLAMA_CLOUD_KEY=
OLLAMA_CLOUD_MODEL=llama3.1:8b

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mistral - https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# xAI (Grok) - https://console.x.ai/
XAI_API_KEY=

# DeepSeek - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Together AI - https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# Fireworks AI - https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=


###############################
# AI PROVIDER RATE LIMITS
###############################

# Requests-per-minute (RPM) / Requests-per-day (RPD) per provider
# Defaults: 60 RPM / 10000 RPD if not set
GROQ_RPM=30
GROQ_RPD=14400
ANTHROPIC_RPM=50
ANTHROPIC_RPD=10000
OPENAI_RPM=60
OPENAI_RPD=10000
GEMINI_RPM=60
GEMINI_RPD=10000
DEEPSEEK_RPM=60
DEEPSEEK_RPD=10000
TOGETHER_RPM=600
TOGETHER_RPD=100000
FIREWORKS_RPM=600
FIREWORKS_RPD=100000

# AI request timeout (seconds)
AI_TIMEOUT=60


###############################
# VOICE & LISTENING
###############################

# Text-to-Speech Engine
VOICE_ENGINE=sapi5
VOICE_RATE=205
VOICE_VOLUME=0.9
VOICE_GENDER=female
LADA_GLOBAL_HOTKEYS_ENABLED=false

# Language Support
TAMIL_MODE=true
AUTO_DETECT_LANGUAGE=true
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ta

# Speech Recognition
SPEECH_TIMEOUT_SEC=5
PHRASE_TIME_LIMIT=10

# Wake Word
ENABLE_STREAMING=true
WAKEWORD_REQUIRED=false
WAKEWORDS=lada,hey lada
STREAM_BUFFER_SIZE=50

# gTTS (online, natural voice)
USE_GTTS=true
GTTS_SLOW=false

# pyttsx3 (offline fallback)
OFFLINE_VOICE_RATE=205
OFFLINE_VOICE_VOLUME=0.9


###############################
# PATHS & DIRECTORIES
###############################

DATA_DIR=./data
LOGS_DIR=./logs
SCREENSHOTS_DIR=./screenshots
CACHE_DIR=./cache
AUDIT_DIR=./audit
TEMPLATES_PATH=./tasks_templates.json

LOG_FILE=logs/lada.log
LOG_LEVEL=INFO

AUDIT_DB_PATH=./audit/jarvis_audit.db
MAX_UNDO_ACTIONS=50


###############################
# PRIVACY & SAFETY
###############################

# Privacy mode: PUBLIC | PRIVATE | SECURE
PRIVACY_MODE=PUBLIC
AUTO_UNDO_ON_ERROR=true

# Paths blocked from modification
PROTECTED_PATHS=C:\Windows,C:\Program Files,C:\Windows\System32

# Commands blocked from execution
COMMAND_BLACKLIST=format disk,delete system32,rm -rf /


###############################
# SYSTEM CONTROL
###############################

MIN_VOLUME=0
MAX_VOLUME=100
DEFAULT_VOLUME=50

MIN_BRIGHTNESS=10
MAX_BRIGHTNESS=100
DEFAULT_BRIGHTNESS=75

SHUTDOWN_CONFIRM_TIME=60
WIFI_AUTO_CONNECT=false
PROCESS_KILL_TIMEOUT=5


###############################
# NLU ENGINE
###############################

INTENT_CONFIDENCE_THRESHOLD=0.6
USE_SPACY_NER=true
SPACY_MODEL=en_core_web_sm


###############################
# TASK AUTOMATION
###############################

TASK_TIMEOUT_DEFAULT=300
TASK_MAX_RETRIES=3
TASK_RETRY_DELAY=5
TASK_QUEUE_SIZE=50

ALLOW_PARALLEL_TASKS=true
MAX_PARALLEL_TASKS=5
WORKER_THREAD_COUNT=4


###############################
# MEMORY & LEARNING
###############################

MAX_HISTORY_MESSAGES=20
MEMORY_PERSISTENCE=true
MEMORY_AUTOSAVE_INTERVAL=300

ENABLE_USER_PREFERENCES=true
ENABLE_CONTEXT_LEARNING=true

MEMORY_FILE=data/jarvis_memory.pkl
PREFERENCES_FILE=data/preferences.json


###############################
# RESPONSE CACHING
###############################

CACHE_ENABLED=true
CACHE_MAX_SIZE=200
CACHE_TTL_HOURS=1

ENABLE_RESPONSE_CACHE=true
ENABLE_QUERY_CACHE=true


###############################
# HEALTH MONITORING
###############################

HEALTH_CHECK_INTERVAL=30
CACHE_CLEANUP_INTERVAL=600

LOCAL_TIMEOUT=60
CLOUD_TIMEOUT=60
GEMINI_TIMEOUT=60

MONITOR_CPU=true
MONITOR_MEMORY=true
MONITOR_DISK=true
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85


###############################
# BROWSER AUTOMATION
###############################

DEFAULT_BROWSER=chrome
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
DEFAULT_SEARCH_ENGINE=google
SEARCH_TIMEOUT=30


###############################
# CONVERSATION & RESPONSES
###############################

SYSTEM_PROMPT=You are LADA (Language Agnostic Digital Assistant), an advanced personal AI assistant. Be conversational, concise, and helpful.

RESPONSE_MAX_LENGTH=2000
VOICE_RESPONSE_MAX_LENGTH=300
STREAMING_ENABLED=true
CONVERSATION_MAX_TURNS=10


###############################
# INTEGRATIONS (Optional)
###############################

# Search Provider (duckduckgo, tavily)
SEARCH_PROVIDER=duckduckgo
# Use DuckDuckGo for simple queries and Tavily for research (saves credits)
SMART_SEARCH_ROUTING=true

# Tavily AI Search - https://tavily.com/
TAVILY_API_KEY=ENTER_TRAVILY_API_KEY

# OpenWeatherMap - https://openweathermap.org/api
OPENWEATHER_API_KEY=
WEATHER_CITY=
WEATHER_COUNTRY=

# Spotify - https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Philips Hue
HUE_BRIDGE_IP=
HUE_USER=

# ElevenLabs Voice (optional premium TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# OpenClaw Compatibility (optional; disabled by default)
LADA_OPENCLAW_MODE=false
LADA_OPENCLAW_COMPAT_RPM=30
LADA_OPENCLAW_WS_COMPAT_ENABLED=true
LADA_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
LADA_OPENCLAW_RECONNECT=true
LADA_OPENCLAW_DEBUG=false
LADA_SKILL_MD_ENABLED=true

# Stealth browser rollout and safety bounds
LADA_STEALTH_BROWSER_ENABLED=true
LADA_STEALTH_DOMAIN_ALLOWLIST=
LADA_STEALTH_MAX_NAVIGATION_DEPTH=25
LADA_STEALTH_COMMAND_TIMEOUT_SEC=30


###############################
# MESSAGING CONNECTORS
###############################

# Telegram Bot
# Create bot via @BotFather: https://core.telegram.org/bots/tutorial
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# Discord Bot
# Create app: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Slack Bot
# Create app: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# WhatsApp (Twilio)
# Sign up: https://www.twilio.com/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Mattermost
# Create bot: Settings > Integrations > Bot Accounts
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_BOT_NAME=lada-bot

# Microsoft Teams
# Register app: https://portal.azure.com
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# LINE Messaging
# Create channel: https://developers.line.biz/console/
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=

# Signal (via signal-cli REST API)
# Set up: https://github.com/bbernhard/signal-cli-rest-api
SIGNAL_PHONE=
SIGNAL_CLI_URL=http://localhost:8080

# Matrix / Element
# Get token: Settings > Help & About > Access Token
MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
MATRIX_BOT_USER_ID=

# DM Pairing Policy: allow (default), deny, pair
DM_PAIRING_POLICY=allow
APPROVED_SENDERS_FILE=data/approved_senders.json

# Away / Auto-Reply
AWAY_MESSAGE=
AWAY_AFTER_SECONDS=0


###############################
# PLUGIN SYSTEM
###############################

# Remote plugin index URL (optional, for marketplace)
PLUGIN_INDEX_URL=
# Local plugin index file
PLUGIN_INDEX_FILE=plugins/marketplace_index.json


###############################
# FEATURE FLAGS
###############################

ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_SCREENSHOTS=true
ENABLE_SYSTEM_CONTROL=true
ENABLE_TASK_AUTOMATION=true
ENABLE_FILE_OPERATIONS=true
ENABLE_BROWSER_CONTROL=true
ENABLE_SAFETY_CONTROLLER=true
ENABLE_NLU_ENGINE=true
ENABLE_MEMORY_SYSTEM=true
ENABLE_HEALTH_MONITOR=true
ENABLE_ADVANCED_FEATURES=true

# Tool contract versions (major versions must match)
LADA_TOOL_CONTRACT_VERSION=1.0
LADA_TOOL_HANDLER_CONTRACT_VERSION=1.0

# Staged rollout level for external exposure controls
# Values: disabled | local | internal | canary | public
LADA_ROLLOUT_STAGE=local

# Web/API auth settings (set in production)
LADA_WEB_PASSWORD=
LADA_JWT_SECRET=

# CORS (comma-separated origins)
LADA_CORS_ORIGINS=http://localhost:5000

# Remote control API controls
LADA_REMOTE_CONTROL_ENABLED=false
LADA_REMOTE_DOWNLOAD_ENABLED=false
LADA_REMOTE_ALLOW_DANGEROUS=false
LADA_REMOTE_ALLOWED_COMMANDS=
LADA_REMOTE_ALLOWED_ROOTS=
LADA_REMOTE_COMMAND_RPM=30
LADA_REMOTE_FILES_RPM=60
LADA_REMOTE_DOWNLOAD_RPM=30

# On-demand remote bridge (Render -> local laptop)
# Keep bridge OFF by default; start bridge manually only when needed.
LADA_REMOTE_BRIDGE_SERVER_URL=
LADA_REMOTE_BRIDGE_PASSWORD=
LADA_REMOTE_BRIDGE_DEVICE_ID=laptop-main
LADA_REMOTE_BRIDGE_LABEL=Main Laptop
LADA_REMOTE_BRIDGE_DEFAULT_DEVICE_ID=
LADA_REMOTE_BRIDGE_AUTO_DISPATCH=
LADA_REMOTE_BRIDGE_API_PREFIX=
LADA_REMOTE_BRIDGE_VERIFY_TLS=true
LADA_REMOTE_BRIDGE_IDLE_POLL_INTERVAL_SEC=8
LADA_REMOTE_BRIDGE_ACTIVE_POLL_INTERVAL_SEC=1
LADA_REMOTE_BRIDGE_ACTIVE_WINDOW_SEC=20
LADA_REMOTE_BRIDGE_HEARTBEAT_SEC=20
LADA_REMOTE_BRIDGE_RECONNECT_SEC=3
LADA_REMOTE_BRIDGE_AUTO_START_APP=true


###############################
# TESTING & DEBUG
###############################

TEST_MODE=false
DEBUG_MODE=false
VERBOSE_LOGGING=false
PRINT_TIMESTAMPS=true


###############################
# DEPLOYMENT
###############################

ENV_NAME=production
PYTHON_VERSION=3.11.9
PLATFORM=windows
AUTO_UPDATE_ENABLED=false
