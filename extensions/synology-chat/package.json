{
  "name": "@lada/synology-chat",
  "version": "2026.4.6",
  "description": "Synology Chat channel plugin for LADA",
  "type": "module",
  "devDependencies": {
    "@lada/plugin-sdk": "workspace:*"
  },
  "lada": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to LADA with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@lada/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.6"
    }
  }
}

